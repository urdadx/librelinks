# Learn how to set it up here: https://www.mongodb.com/docs/guides/atlas/connection-string/
DATABASE_URL=


# Required for Google Auth
# Learn how to set this up here: https://better-auth.com/docs/authentication/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NODE_ENV="development"

# Better Auth
# Local: http://localhost:3000
# Production: your public app URL, e.g. https://links.urdadx.com
BETTER_AUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
